generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(uuid())
  name            String
  email           String          @unique
  passwordHash    String
  role            UserRole        @default(CITIZEN)
  authorityCode   String?
  authorityBody   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  comments        Comment[]
  timelineEntries IssueTimeline[]
  mlaReviews      MlaReview[]
  assignedReports Report[]        @relation("ReportAuthority")
  reports         Report[]        @relation("ReportCreator")
  upvotes         Upvote[]

  @@index([role])
}

model Ward {
  id              String   @id @default(uuid())
  name            String   @unique
  zone            String?
  geojsonBoundary Json?
  mlaId           String?  @unique
  mla             Mla?
  reports         Report[]
}

model Mla {
  id            String      @id @default(uuid())
  name          String
  party         String?
  photoUrl      String?
  yearsInOffice Int?
  constituency  String?
  wardId        String?     @unique
  ward          Ward?       @relation(fields: [wardId], references: [id])
  mlaReviews    MlaReview[]
  reports       Report[]
}

model Report {
  id                  String          @id @default(uuid())
  title               String
  description         String
  category            ReportCategory
  status              ReportStatus    @default(REPORTED)
  areaName            String
  mapAreaText         String?
  latitude            Float?
  longitude           Float?
  locationText        String?
  wardId              String?
  assignedMlaId       String?
  mlaName             String?
  constituencyName    String?
  assignedAuthorityId String?
  createdById         String
  citizenPhotoUrl     String?
  fixPhotoUrl         String?
  rejectionReason     String?
  upvoteCount         Int             @default(0)
  escalated           Boolean         @default(false)
  escalatedAt         DateTime?
  citizenVerified     Boolean?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  comments            Comment[]
  timeline            IssueTimeline[]
  assignedAuthority   User?           @relation("ReportAuthority", fields: [assignedAuthorityId], references: [id])
  assignedMla         Mla?            @relation(fields: [assignedMlaId], references: [id])
  createdBy           User            @relation("ReportCreator", fields: [createdById], references: [id])
  ward                Ward?           @relation(fields: [wardId], references: [id])
  images              ReportImage[]
  upvotes             Upvote[]

  @@index([createdById])
  @@index([status])
  @@index([category])
  @@index([assignedAuthorityId])
  @@index([assignedMlaId])
  @@index([wardId])
}

model ReportImage {
  id        String   @id @default(uuid())
  reportId  String
  isMain    Boolean  @default(false)
  url       String
  createdAt DateTime @default(now())
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model IssueTimeline {
  id        String         @id @default(uuid())
  issueId   String
  actorId   String?
  actorName String
  actorRole String
  action    TimelineAction
  note      String?
  createdAt DateTime       @default(now())
  actor     User?          @relation(fields: [actorId], references: [id])
  issue     Report         @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId])
}

model Comment {
  id         String   @id @default(uuid())
  issueId    String
  userId     String
  content    String
  isOfficial Boolean  @default(false)
  createdAt  DateTime @default(now())
  issue      Report   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])

  @@index([issueId])
}

model Upvote {
  id        String   @id @default(uuid())
  issueId   String
  userId    String
  createdAt DateTime @default(now())
  issue     Report   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([issueId, userId])
  @@index([issueId])
}

model MlaReview {
  id        String   @id @default(uuid())
  mlaId     String
  citizenId String
  content   String
  createdAt DateTime @default(now())
  citizen   User     @relation(fields: [citizenId], references: [id])
  mla       Mla      @relation(fields: [mlaId], references: [id])

  @@index([mlaId])
}

enum UserRole {
  CITIZEN
  AUTHORITY
}

enum ReportStatus {
  REPORTED
  ASSIGNED
  IN_PROGRESS
  RESOLVED_PENDING_VERIFICATION
  CONFIRMED_FIXED
  REOPENED
  REJECTED
}

enum ReportCategory {
  POTHOLES
  GARBAGE
  WATER_LEAKAGE
  DRAINAGE_SEWAGE
  STREETLIGHT
  ROAD_DAMAGE
  ILLEGAL_DUMPING
  STRAY_ANIMALS
  TRAFFIC_SIGNAL
  ENCROACHMENT
  BUILDING
  FLOODING
  OTHER
}

enum TimelineAction {
  REPORTED
  ASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  FIX_PHOTO_UPLOADED
  CITIZEN_VERIFIED
  CITIZEN_REOPENED
  REJECTED
  ESCALATED
}
