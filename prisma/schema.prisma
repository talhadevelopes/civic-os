generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CITIZEN
  AUTHORITY
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(CITIZEN)

  authorityCode String?
  authorityBody String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([role])
}
